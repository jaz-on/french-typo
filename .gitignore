# Exclude files from WordPress.org releases
.gitattributes
.DS_Store
*.swp
*.swo
*~
.vscode/
.idea/
# Cursor IDE: ignore local state; version shared rules (excluded from WP.org via .distignore)
.cursor/*
!.cursor/rules/
!.cursor/rules/**

# Exclude compiled translation files (.mo files are generated from .po files)
languages/*.mo

# Composer dependencies
vendor/
composer/

# PHP CodeSniffer cache
.phpcs-cache/

# PHPUnit (suite not adopted yet; remove these ignores when committing phpunit.xml.dist)
phpunit.xml
phpunit.xml.dist

# PHPUnit cache
.phpunit.result.cache
.phpunit.cache/


# Dossier local (notes, plans hors dépôt)
_local/
_todo/
